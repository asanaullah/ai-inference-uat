apiVersion: tekton.dev/v1
kind: Task
metadata:
  name: {{ task_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
spec:
  params:
    - name: timestamp
      type: string
  steps:
    - name: run-test
      image: {{ ose_cli_image }}
      script: |
        oc apply -f - <<'MANIFEST_EOF'
        {{ manifest | indent(8) }}
        MANIFEST_EOF

        echo "Waiting for pod {{ pod_name }} to complete..."
        while true; do
          PHASE=$(oc get pod {{ pod_name }} -o jsonpath='{.status.phase}' 2>/dev/null || echo "Pending")
          case "$PHASE" in
            Succeeded)
              echo "Pod {{ pod_name }} completed successfully"
              exit 0
              ;;
            Failed)
              echo "Pod {{ pod_name }} failed"
              oc logs {{ pod_name }} --tail=50 || true
              exit 1
              ;;
            *)
              sleep 5
              ;;
          esac
        done
