apiVersion: tekton.dev/v1
kind: Pipeline
metadata:
  name: {{ pipeline_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
spec:
  tasks:
{% for task in tasks %}
    - name: {{ task.name }}
      taskRef:
        name: {{ task.ref_name }}
{% if task.params is defined and task.params %}
      params:
{% for p in task.params %}
        - name: {{ p.name }}
          value: {{ p.value | yaml_quote }}
{% endfor %}
{% endif %}
{% if task.run_after is defined and task.run_after %}
      runAfter:
{% for dep in task.run_after %}
        - {{ dep }}
{% endfor %}
{% endif %}
{% if task.when_expressions is defined and task.when_expressions %}
      when:
{% for w in task.when_expressions %}
        - input: {{ w.input }}
          operator: {{ w.operator }}
          values:
{% for v in w["values"] %}
            - {{ v }}
{% endfor %}
{% endfor %}
{% endif %}
{% if task.on_error is defined and task.on_error %}
      onError: {{ task.on_error }}
{% endif %}
{% endfor %}
{% if finally_tasks %}
  finally:
{% for task in finally_tasks %}
    - name: {{ task.name }}
      taskRef:
        name: {{ task.ref_name }}
{% if task.run_after is defined and task.run_after %}
      runAfter:
{% for dep in task.run_after %}
        - {{ dep }}
{% endfor %}
{% endif %}
{% if task.on_error is defined and task.on_error %}
      onError: {{ task.on_error }}
{% endif %}
{% endfor %}
{% endif %}
