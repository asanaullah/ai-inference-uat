apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ configmap_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
data:
{% for filename, content in files.items() %}
  {{ filename }}: |
{{ content | indent(4, first=True) }}
{% endfor %}
