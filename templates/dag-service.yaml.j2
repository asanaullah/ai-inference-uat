apiVersion: v1
kind: Service
metadata:
  name: {{ service_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
    test: {{ test }}
    node: {{ node }}
spec:
{% if headless %}
  clusterIP: None
{% endif %}
  selector:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
    test: {{ test }}
    node: {{ node }}
  ports:
    - port: {{ port }}
      targetPort: {{ port }}
