apiVersion: v1
kind: Service
metadata:
  name: {{ service_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
    test: {{ test }}
    dag-step: {{ dag_step_name }}
{% if node %}
    node: {{ node }}
{% endif %}
{% if sweep_id is defined %}
    sweep: {{ sweep_id }}
{% endif %}
spec:
{% if headless %}
  clusterIP: None
{% endif %}
  selector:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
    test: {{ test }}
    dag-step: {{ dag_step_name }}
{% if node %}
    node: {{ node }}
{% endif %}
  ports:
    - port: {{ port }}
      targetPort: {{ port }}
