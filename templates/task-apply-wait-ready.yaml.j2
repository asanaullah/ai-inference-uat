apiVersion: tekton.dev/v1
kind: Task
metadata:
  name: {{ task_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
spec:
  params:
    - name: timestamp
      type: string
  steps:
    - name: apply-and-wait
      image: {{ ose_cli_image }}
      script: |
        oc apply -f - <<'MANIFEST_EOF'
        {{ manifest | indent(8) }}
        MANIFEST_EOF
{% if wait_ready %}
        echo "Waiting for {{ pod_name }} to be ready..."
        oc wait --for=condition=Ready pod/{{ pod_name }} --timeout={{ timeout }}
{% endif %}
