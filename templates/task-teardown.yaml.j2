apiVersion: tekton.dev/v1
kind: Task
metadata:
  name: {{ task_name }}
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: {{ managed_by_label }}
spec:
  params:
    - name: timestamp
      type: string
  steps:
    - name: teardown
      image: {{ ose_cli_image }}
      script: |
        echo "Tearing down resources with selector: {{ selector }}"
        oc delete pods,services,deployments -l {{ selector }} --ignore-not-found
        echo "Teardown complete"
