digraph architecture {
    rankdir=TB
    fontname="Helvetica"
    bgcolor="white"
    dpi=150
    pad="0.6"
    nodesep=0.8
    ranksep=1.0
    compound=true
    newrank=true

    node [fontname="Helvetica" fontsize=11 shape=box style="rounded,filled"
          fillcolor="#f8f9fa" color="#dee2e6" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#4a5568" arrowsize=0.9 penwidth=1.5]

    // ═══════════════════════════════════════════════════════
    //  INPUTS
    // ═══════════════════════════════════════════════════════

    test_suite [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
               BGCOLOR="#e4edf8" COLOR="#3b78d1" STYLE="ROUNDED">
            <TR><TD COLSPAN="2" BGCOLOR="#3b78d1">
                <FONT COLOR="white" POINT-SIZE="13"><B>Test Suite</B></FONT>
            </TD></TR>
            <TR><TD ALIGN="LEFT" COLSPAN="2">
                <FONT POINT-SIZE="11"><B>test_suite.yaml</B></FONT><BR ALIGN="LEFT"/>
                <FONT POINT-SIZE="10" COLOR="#555">tests by scope (node / cluster / project)</FONT>
            </TD></TR>
            <TR><TD ALIGN="LEFT" COLSPAN="2">
                <FONT POINT-SIZE="11"><B>&lt;test&gt;.yaml</B> + <B>&lt;test&gt;.go</B></FONT><BR ALIGN="LEFT"/>
                <FONT POINT-SIZE="10" COLOR="#555">DAG, server config, sweep params, Ginkgo logic</FONT>
            </TD></TR>
        </TABLE>
    >]

    cluster_config [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
               BGCOLOR="#fae8e6" COLOR="#d44332" STYLE="ROUNDED">
            <TR><TD BGCOLOR="#d44332">
                <FONT COLOR="white" POINT-SIZE="13"><B>Cluster Config</B></FONT>
            </TD></TR>
            <TR><TD ALIGN="LEFT">
                <FONT POINT-SIZE="11"><B>ocp-test.yaml</B></FONT><BR ALIGN="LEFT"/>
                <FONT POINT-SIZE="10" COLOR="#555">target nodes, namespace,<BR ALIGN="LEFT"/>storage, GPU specs</FONT>
            </TD></TR>
        </TABLE>
    >]

    gen_config [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
               BGCOLOR="#fdf6e0" COLOR="#d4960a" STYLE="ROUNDED">
            <TR><TD BGCOLOR="#d4960a">
                <FONT COLOR="white" POINT-SIZE="13"><B>Generator Config</B></FONT>
            </TD></TR>
            <TR><TD ALIGN="LEFT">
                <FONT POINT-SIZE="11"><B>config.yaml</B></FONT><BR ALIGN="LEFT"/>
                <FONT POINT-SIZE="10" COLOR="#555">images, pod names, labels</FONT>
            </TD></TR>
        </TABLE>
    >]

    {rank=same; test_suite; cluster_config; gen_config}
    test_suite -> cluster_config -> gen_config [style=invis]

    // ═══════════════════════════════════════════════════════
    //  GENERATOR
    // ═══════════════════════════════════════════════════════

    generator [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="4" CELLPADDING="10"
               BGCOLOR="#e4f3e9" COLOR="#2e944a" STYLE="ROUNDED">
            <TR><TD COLSPAN="7" BGCOLOR="#2e944a" CELLPADDING="12">
                <FONT COLOR="white" POINT-SIZE="13"><B>python -m src</B></FONT>
                <FONT COLOR="#b8dfc5" POINT-SIZE="10">  common.py → node.py → generate.py</FONT>
            </TD></TR>
            <TR>
                <TD BGCOLOR="#c2e4cd">Load &amp;<BR/>Validate<BR/><FONT POINT-SIZE="9" COLOR="#555">Pydantic</FONT></TD>
                <TD BGCOLOR="#e4f3e9"><FONT POINT-SIZE="16" COLOR="#2e944a">→</FONT></TD>
                <TD BGCOLOR="#c2e4cd">Compute<BR/>Steps</TD>
                <TD BGCOLOR="#e4f3e9"><FONT POINT-SIZE="16" COLOR="#2e944a">→</FONT></TD>
                <TD BGCOLOR="#c2e4cd">Render &amp;<BR/>Validate<BR/><FONT POINT-SIZE="9" COLOR="#555">Jinja2 + YAML</FONT></TD>
                <TD BGCOLOR="#e4f3e9"><FONT POINT-SIZE="16" COLOR="#2e944a">→</FONT></TD>
                <TD BGCOLOR="#c2e4cd">Write<BR/>Manual &amp;<BR/>Tekton</TD>
            </TR>
        </TABLE>
    >]

    // ═══════════════════════════════════════════════════════
    //  BUILD OUTPUT
    // ═══════════════════════════════════════════════════════

    build_output [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="4" CELLPADDING="10"
               BGCOLOR="#f0e6f8" COLOR="#7e2ec8" STYLE="ROUNDED">
            <TR><TD COLSPAN="2" BGCOLOR="#7e2ec8" CELLPADDING="12">
                <FONT COLOR="white" POINT-SIZE="13"><B>build/</B></FONT>
            </TD></TR>
            <TR>
                <TD BGCOLOR="#e2d0f0"><FONT POINT-SIZE="11"><B>manual/</B></FONT><BR/>
                    <FONT POINT-SIZE="10" COLOR="#555">setup/, nodes/&lt;node&gt;/, teardown/</FONT><BR/>
                    <FONT POINT-SIZE="9" COLOR="#888">standalone pods &amp; scripts</FONT>
                </TD>
                <TD BGCOLOR="#e2d0f0"><FONT POINT-SIZE="11"><B>tekton/</B></FONT><BR/>
                    <FONT POINT-SIZE="10" COLOR="#555">pipelines, tasks, configmap</FONT><BR/>
                    <FONT POINT-SIZE="9" COLOR="#888">derived from same step list</FONT>
                </TD>
            </TR>
        </TABLE>
    >]

    // ═══════════════════════════════════════════════════════
    //  EXECUTION
    // ═══════════════════════════════════════════════════════

    subgraph cluster_execution {
        label=<<FONT POINT-SIZE="14"><B>EXECUTION</B></FONT><FONT POINT-SIZE="10" COLOR="#666">  OpenShift / Tekton</FONT>>
        labeljust=l
        style="rounded,filled"
        fillcolor="#fef8e1"
        color="#d4960a"
        fontname="Helvetica"
        penwidth=2
        margin=20

        subgraph cluster_cluster_pipeline {
            label=<<FONT POINT-SIZE="12"><B>Cluster Pipeline</B></FONT>>
            labeljust=l
            style="rounded,filled"
            fillcolor="#fdf0c8"
            color="#cc8a00"
            fontname="Helvetica"
            penwidth=1.5
            margin=20

            create_builder [label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD><FONT POINT-SIZE="14" COLOR="#996600"><B>1</B></FONT></TD>
                        <TD><FONT POINT-SIZE="11">  Create Builder Pod</FONT></TD></TR>
                </TABLE>>
                fillcolor="#ffe8b8" color="#cc8a00"]
            build_binaries [label=<
                <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD><FONT POINT-SIZE="14" COLOR="#996600"><B>2</B></FONT></TD>
                        <TD><FONT POINT-SIZE="11">  Build Binaries</FONT></TD></TR>
                </TABLE>>
                fillcolor="#ffe8b8" color="#cc8a00"]

            fan_out [shape=diamond width=0.2 height=0.2 fixedsize=true
                     label="" fillcolor="#cc8a00" color="#cc8a00"]

            subgraph cluster_node_pipes {
                label=<
                    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
                        <TR><TD><FONT POINT-SIZE="14" COLOR="#996600"><B>3</B></FONT></TD>
                            <TD><FONT POINT-SIZE="12"><B>  Node Pipelines</B></FONT></TD>
                            <TD><FONT POINT-SIZE="10" COLOR="#888">  ×N nodes, parallel</FONT></TD></TR>
                    </TABLE>>
                labeljust=l
                style="rounded,filled"
                fillcolor="#fef8e1"
                color="#b37800"
                fontname="Helvetica"
                penwidth=1.5
                margin=16

                node_pipe_1 [shape=plaintext margin=0 label=<
                    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
                           WIDTH="200" BGCOLOR="#fdf0c8" COLOR="#b37800" STYLE="ROUNDED">
                        <TR><TD BGCOLOR="#b37800">
                            <FONT COLOR="white" POINT-SIZE="11"><B>Node 1 Pipeline</B></FONT>
                        </TD></TR>
                        <TR><TD ALIGN="LEFT">
                            <FONT POINT-SIZE="10" COLOR="#666">nodeSelector: node-1</FONT><BR ALIGN="LEFT"/>
                            <BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">deploy DAG → wait ready</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ run steps (single/sweep)</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ teardown DAG</FONT>
                        </TD></TR>
                    </TABLE>
                >]

                node_pipe_2 [shape=plaintext margin=0 label=<
                    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
                           WIDTH="200" BGCOLOR="#fdf0c8" COLOR="#b37800" STYLE="ROUNDED">
                        <TR><TD BGCOLOR="#b37800">
                            <FONT COLOR="white" POINT-SIZE="11"><B>Node 2 Pipeline</B></FONT>
                        </TD></TR>
                        <TR><TD ALIGN="LEFT">
                            <FONT POINT-SIZE="10" COLOR="#666">nodeSelector: node-2</FONT><BR ALIGN="LEFT"/>
                            <BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">deploy DAG → wait ready</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ run steps (single/sweep)</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ teardown DAG</FONT>
                        </TD></TR>
                    </TABLE>
                >]

                node_pipe_n [shape=plaintext margin=0 label=<
                    <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10"
                           WIDTH="200" BGCOLOR="#fdf0c8" COLOR="#b37800" STYLE="ROUNDED">
                        <TR><TD BGCOLOR="#b37800">
                            <FONT COLOR="white" POINT-SIZE="11"><B>Node N Pipeline</B></FONT>
                        </TD></TR>
                        <TR><TD ALIGN="LEFT">
                            <FONT POINT-SIZE="10" COLOR="#666">nodeSelector: node-N</FONT><BR ALIGN="LEFT"/>
                            <BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">deploy DAG → wait ready</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ run steps (single/sweep)</FONT><BR ALIGN="LEFT"/>
                            <FONT FACE="Courier" POINT-SIZE="10">→ teardown DAG</FONT>
                        </TD></TR>
                    </TABLE>
                >]

                {rank=same; node_pipe_1; node_pipe_2; node_pipe_n}
                node_pipe_1 -> node_pipe_2 -> node_pipe_n [style=invis]
            }

            fan_in [shape=diamond width=0.2 height=0.2 fixedsize=true
                    label="" fillcolor="#cc8a00" color="#cc8a00"]

            cluster_tests [shape=plaintext margin=0 label=<
                <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="12"
                       BGCOLOR="#e4e7f3" COLOR="#354999" STYLE="ROUNDED">
                    <TR><TD BGCOLOR="#354999">
                        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
                            <TR><TD><FONT COLOR="white" POINT-SIZE="14"><B>4</B></FONT></TD>
                                <TD><FONT COLOR="white" POINT-SIZE="12"><B>  Cluster Tests</B></FONT></TD>
                                <TD><FONT COLOR="#9aa1cc" POINT-SIZE="10">  e.g. RDMA perftest</FONT></TD></TR>
                        </TABLE>
                    </TD></TR>
                    <TR><TD ALIGN="LEFT">
                        <FONT POINT-SIZE="10">Multi-node coordinated tests.</FONT><BR ALIGN="LEFT"/>
                        <FONT POINT-SIZE="10">Cluster pipeline orchestrates tasks across nodes directly.</FONT><BR ALIGN="LEFT"/>
                        <BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">cluster → task on node A (server)</FONT><BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">        → task on node B (client)</FONT><BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">        → collect results</FONT>
                    </TD></TR>
                </TABLE>
            >]

            project_tests [shape=plaintext margin=0 label=<
                <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="12"
                       BGCOLOR="#e8f0e4" COLOR="#3a7d34" STYLE="ROUNDED">
                    <TR><TD BGCOLOR="#3a7d34">
                        <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
                            <TR><TD><FONT COLOR="white" POINT-SIZE="14"><B>5</B></FONT></TD>
                                <TD><FONT COLOR="white" POINT-SIZE="12"><B>  Project Tests</B></FONT></TD>
                                <TD><FONT COLOR="#a3d49e" POINT-SIZE="10">  e.g. quotas, RBAC</FONT></TD></TR>
                        </TABLE>
                    </TD></TR>
                    <TR><TD ALIGN="LEFT">
                        <FONT POINT-SIZE="10">Namespace-level tests, no node affinity.</FONT><BR ALIGN="LEFT"/>
                        <FONT POINT-SIZE="10">Validates project-wide concerns after cluster tests.</FONT><BR ALIGN="LEFT"/>
                        <BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">project → run quota/RBAC checks</FONT><BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">        → validate network policies</FONT><BR ALIGN="LEFT"/>
                        <FONT FACE="Courier" POINT-SIZE="10">        → collect results</FONT>
                    </TD></TR>
                </TABLE>
            >]

            subgraph cluster_finally {
                label=<<FONT POINT-SIZE="11"><I>finally</I></FONT>>
                labeljust=l
                style="rounded,dashed"
                fillcolor="#fdf0c8"
                color="#b37800"
                fontname="Helvetica"
                penwidth=1.5
                margin=16

                aggregate [label=<
                    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6">
                        <TR><TD><FONT POINT-SIZE="14" COLOR="#996600"><B>6</B></FONT></TD>
                            <TD><FONT POINT-SIZE="11">  Aggregate Results</FONT></TD></TR>
                    </TABLE>>
                    fillcolor="#ffe8b8" color="#cc8a00"]
                cleanup_step [label=<
                    <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6">
                        <TR><TD><FONT POINT-SIZE="14" COLOR="#996600"><B>7</B></FONT></TD>
                            <TD><FONT POINT-SIZE="11">  Cleanup</FONT></TD></TR>
                    </TABLE>>
                    fillcolor="#ffe8b8" color="#cc8a00"]
            }

            // edges within cluster pipeline
            create_builder -> build_binaries
            build_binaries -> fan_out [arrowhead=none]
            fan_out -> node_pipe_1
            fan_out -> node_pipe_2
            fan_out -> node_pipe_n
            node_pipe_1 -> fan_in
            node_pipe_2 -> fan_in
            node_pipe_n -> fan_in
            fan_in -> cluster_tests [label=<<FONT POINT-SIZE="10">all node pipelines complete</FONT>>]
            cluster_tests -> project_tests
            project_tests -> aggregate [style=dashed]
            aggregate -> cleanup_step
        }
    }

    // ═══════════════════════════════════════════════════════
    //  RESULTS
    // ═══════════════════════════════════════════════════════

    results [shape=plaintext margin=0 label=<
        <TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="12"
               BGCOLOR="#e4f3e5" COLOR="#2a7030" STYLE="ROUNDED">
            <TR><TD BGCOLOR="#2a7030">
                <FONT COLOR="white" POINT-SIZE="13"><B>RESULTS</B></FONT>
                <FONT COLOR="#a0d4a3" POINT-SIZE="10">  PVC</FONT>
            </TD></TR>
            <TR><TD ALIGN="LEFT">
                <FONT FACE="Courier" POINT-SIZE="10">
&lt;basePath&gt;/&lt;timestamp&gt;/<BR ALIGN="LEFT"/>
├── binaries/&lt;test&gt;/test.bin<BR ALIGN="LEFT"/>
├── node/&lt;node&gt;/&lt;test&gt;/&lt;dag&gt;/  <FONT COLOR="#666"># per-step dir</FONT><BR ALIGN="LEFT"/>
│     junit.xml, benchmarks<BR ALIGN="LEFT"/>
├── cluster/                    <FONT COLOR="#666"># future</FONT><BR ALIGN="LEFT"/>
├── project/                    <FONT COLOR="#666"># future</FONT><BR ALIGN="LEFT"/>
└── report/<BR ALIGN="LEFT"/>
      summary.json              <FONT COLOR="#666"># aggregated</FONT><BR ALIGN="LEFT"/>
                </FONT>
            </TD></TR>
        </TABLE>
    >]

    // ═══════════════════════════════════════════════════════
    //  INTER-PHASE EDGES
    // ═══════════════════════════════════════════════════════

    test_suite     -> generator
    cluster_config -> generator
    gen_config     -> generator

    generator -> build_output [penwidth=1.5]

    build_output -> create_builder [lhead=cluster_execution
        label=<<FONT POINT-SIZE="10"><B>oc create -f</B></FONT>>
        penwidth=1.5]

    cleanup_step -> results [style=invis]
    aggregate -> results [constraint=false penwidth=1.5 color="#2a7030"
        label=<<FONT POINT-SIZE="10" COLOR="#2a7030">write report</FONT>>]
}
